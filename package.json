    "test:interiors": "npx --yes tsx@4.20.6 scripts/daily-life-interiors-smoke.ts",
    "test:race-demography": "npx --yes tsx@4.20.6 scripts/race-demography-smoke.ts",
    "test:population": "npx --yes tsx@4.20.6 scripts/population-migration-smoke.ts",
    "test:pipeline": "npx --yes tsx@4.20.6 scripts/world-simulation-pipeline-smoke.ts",
    "test:deep-interiors": "npx --yes tsx@4.20.6 scripts/deep-interiors-smoke.ts",
    "test:generation-startup": "npx --yes tsx@4.20.6 scripts/generation-startup-smoke.ts",
    "test:city": "npx --yes tsx@4.20.6 scripts/city-simulation-smoke.ts",
    "test:civilization": "npx --yes tsx@4.20.6 scripts/civilization-system-smoke.ts",
    "test:city-generation": "npx --yes tsx@4.20.6 scripts/city-generation-smoke.ts",
    "test:settlement-lifecycle": "npx --yes tsx@4.20.6 scripts/settlement-lifecycle-smoke.ts",
    "test:state-formation": "npx --yes tsx@4.20.6 scripts/state-formation-smoke.ts",
    "test:lived-history": "npx --yes tsx@4.20.6 scripts/lived-history-smoke.ts",
    "test:lived-history-stability": "npx --yes tsx@4.20.6 scripts/lived-history-stability-smoke.ts",
