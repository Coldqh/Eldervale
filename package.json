    "test:ci": "npm run build && npm run test:generation-startup && npm run test:lived-history && npm run test:lived-history-stability && npm run test:watchdog && npm run test:next-event && npm run test:daily-life && npm run test:interiors && npm run test:deep-interiors && npm run test:city && npm run test:city-generation && npm run test:settlement-lifecycle && npm run test:state-formation && npm run test:civilization && npm run test:technology-knowledge && npm run test:race-demography && npm run test:population && npm run test:pipeline && npm run test:live-stories && npm run test:dynasty-legacy && npm run test:climate && npm run test:storage && npm run test:sim && npm run test:battle && npm run test:long && npm run test:perf",
