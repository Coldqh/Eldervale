    "test:next-event": "npx --yes tsx@4.20.6 scripts/next-event-smoke.ts",
    "test:daily-life": "npx --yes tsx@4.20.6 scripts/daily-life-smoke.ts",
    "test:live-stories": "npx --yes tsx@4.20.6 scripts/live-stories-smoke.ts",
